# Blender asset pipeline: the bpy virtualenv is a multi-hundred-MB local
# toolchain, not project source - build_character.py/build_cashbundle.py are
# what's tracked; run them locally to (re)produce the .glb files if needed.
assets/blender/venv/
assets/blender/*_preview*.png
assets/blender/prop_previews/
assets/blender/family_previews/

# graphify knowledge graph: keep the queryable/readable outputs (graph.json,
# GRAPH_REPORT.md, graph.html, manifest.json, .graphify_root) so the graph
# travels with the branch; ignore the local build cache + intermediate files.
graphify-out/cache/
graphify-out/.graphify_analysis.json
graphify-out/.graphify_labels.json
graphify-out/.graphify_labels.json.sig
